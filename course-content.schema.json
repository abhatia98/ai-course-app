{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "AI Course Content",
  "type": "object",
  "required": [
    "course",
    "modules",
    "lessons"
  ],
  "properties": {
    "course": {
      "type": "object",
      "required": [
        "id",
        "slug",
        "title",
        "description",
        "totalLessons"
      ],
      "properties": {
        "id": {
          "type": "string"
        },
        "slug": {
          "type": "string"
        },
        "title": {
          "type": "string"
        },
        "subtitle": {
          "type": "string"
        },
        "description": {
          "type": "string"
        },
        "targetAudience": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "totalLessons": {
          "type": "integer"
        }
      },
      "additionalProperties": true
    },
    "modules": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "id",
          "slug",
          "title",
          "description",
          "order"
        ],
        "properties": {
          "id": {
            "type": "string"
          },
          "slug": {
            "type": "string"
          },
          "title": {
            "type": "string"
          },
          "description": {
            "type": "string"
          },
          "order": {
            "type": "integer"
          }
        },
        "additionalProperties": true
      }
    },
    "lessons": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "id",
          "slug",
          "moduleId",
          "order",
          "title",
          "shortDescription",
          "estimatedMinutes",
          "difficulty",
          "learningObjectives",
          "papers",
          "quiz"
        ],
        "properties": {
          "id": {
            "type": "string"
          },
          "slug": {
            "type": "string"
          },
          "moduleId": {
            "type": "string"
          },
          "order": {
            "type": "integer"
          },
          "title": {
            "type": "string"
          },
          "shortDescription": {
            "type": "string"
          },
          "estimatedMinutes": {
            "type": "integer"
          },
          "difficulty": {
            "type": "string"
          },
          "prerequisites": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "learningObjectives": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "papers": {
            "type": "array",
            "maxItems": 4,
            "items": {
              "type": "object",
              "required": [
                "title",
                "whyItMatters"
              ],
              "properties": {
                "title": {
                  "type": "string"
                },
                "authors": {
                  "type": "string"
                },
                "year": {
                  "type": [
                    "integer",
                    "null"
                  ]
                },
                "whyItMatters": {
                  "type": "string"
                },
                "url": {
                  "type": [
                    "string",
                    "null"
                  ]
                }
              },
              "additionalProperties": true
            }
          },
          "lessonPlan": {
            "type": "object",
            "properties": {
              "summary": {
                "type": "string"
              },
              "sections": {
                "type": "array",
                "items": {
                  "type": "object",
                  "required": [
                    "heading",
                    "content"
                  ],
                  "properties": {
                    "heading": {
                      "type": "string"
                    },
                    "content": {
                      "type": "string"
                    }
                  }
                }
              },
              "keyTerms": {
                "type": "array",
                "items": {
                  "type": "string"
                }
              },
              "takeaways": {
                "type": "array",
                "items": {
                  "type": "string"
                }
              }
            },
            "additionalProperties": true
          },
          "quiz": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "object",
              "required": [
                "id",
                "prompt",
                "type",
                "choices",
                "correctAnswerIndex",
                "explanation"
              ],
              "properties": {
                "id": {
                  "type": "string"
                },
                "prompt": {
                  "type": "string"
                },
                "type": {
                  "type": "string",
                  "enum": [
                    "multiple-choice"
                  ]
                },
                "choices": {
                  "type": "array",
                  "minItems": 2,
                  "items": {
                    "type": "string"
                  }
                },
                "correctAnswerIndex": {
                  "type": "integer"
                },
                "explanation": {
                  "type": "string"
                }
              },
              "additionalProperties": false
            }
          }
        },
        "additionalProperties": true
      }
    }
  },
  "additionalProperties": false
}